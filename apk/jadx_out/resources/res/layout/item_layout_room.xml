<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_layout_room"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_24dp"
    android:layout_marginVertical="@dimen/margin_12dp"
    app:cardElevation="10dp"
    style="@style/ClickableCardViewStyle">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/room_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/default_room_image"
            android:contentDescription="@string/room_image_preview"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/RoomImage"/>
        <com.google.android.material.chip.Chip
            android:id="@+id/room_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_24dp"
            android:text="@string/example_room_name"
            android:elevation="11dp"
            app:layout_constraintBottom_toTopOf="@+id/room_measurements"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:rippleColor="@android:color/transparent"
            style="@style/RoomName"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/room_measurements"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="11dp"
            app:layout_constraintBottom_toBottomOf="@+id/room_image"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/room_image"
            app:layout_constraintVertical_bias="0.45">
            <TextView
                android:textSize="40dp"
                android:textStyle="bold"
                android:textColor="@color/colorMainText"
                android:id="@+id/room_measurements_aqi_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/text_size_12sp"
                android:textStyle="bold"
                android:textColor="@color/colorMainText"
                android:layout_gravity="start"
                android:paddingTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/aqi"
                android:textAllCaps="true"
                android:paddingStart="@dimen/margin_4dp"
                android:paddingEnd="@dimen/margin_8dp"/>
        </LinearLayout>
        <TextView
            android:textSize="30dp"
            android:textStyle="bold"
            android:textColor="@color/colorMainText"
            android:id="@+id/room_measurements_aqi_diagnosis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_16dp"
            android:text="@string/aqi_unknown"
            android:textAllCaps="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/room_measurements"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
