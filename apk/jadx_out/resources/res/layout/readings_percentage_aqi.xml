<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:tag="layout/readings_percentage_aqi_0"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="68dp"
        android:id="@+id/humidity_reading"
        android:tag="binding_1"
        android:paddingTop="0dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/ReadingsAppearance"/>
    <TextView
        android:textSize="32dp"
        android:id="@+id/sign_percent_humidity"
        android:paddingTop="6dp"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sign_percent"
        android:layout_toEndOf="@+id/humidity_reading"
        style="@style/ReadingsAppearance"/>
    <TextView
        android:textSize="10sp"
        android:id="@+id/aqi_norm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-12dp"
        android:text="@string/aqi_type"
        android:layout_below="@+id/humidity_reading"
        android:layout_centerHorizontal="true"
        style="@style/ReadingsAppearance"/>
</RelativeLayout>
