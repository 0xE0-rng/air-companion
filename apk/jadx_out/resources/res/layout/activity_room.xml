<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_room_layout"
    android:tag="layout/activity_room_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="@dimen/elevation_toolbar"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.Toolbar
            android:theme="@style/ToolbarTheme"
            android:id="@+id/activity_room_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:contentInsetStart="0dp"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:gravity="center"
                android:id="@+id/toolbar_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_rooms"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cont"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="10dp"
        app:layout_constraintTop_toBottomOf="@+id/appbar">
        <com.google.android.material.chip.Chip
            android:id="@+id/button_prev_room"
            android:tag="binding_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginStart="14dp"
            app:chipIcon="@drawable/ic_chevron_left_24dp"
            app:layout_constraintEnd_toStartOf="@+id/room_name"
            app:layout_constraintStart_toStartOf="@+id/cont"
            app:layout_constraintTop_toTopOf="@+id/cont"
            style="@style/RoomPagingButton"/>
        <com.google.android.material.chip.Chip
            android:id="@+id/room_name"
            android:tag="binding_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginHorizontal="8dp"
            app:chipSurfaceColor="@color/colorTransparentWhite"
            app:layout_constraintEnd_toStartOf="@+id/button_next_room"
            app:layout_constraintStart_toEndOf="@+id/button_prev_room"
            app:layout_constraintTop_toTopOf="@+id/button_prev_room"
            style="@style/RoomNameChip"/>
        <com.google.android.material.chip.Chip
            android:id="@+id/button_next_room"
            android:tag="binding_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            app:chipIcon="@drawable/ic_chevron_right_24dp"
            app:layout_constraintEnd_toEndOf="@+id/cont"
            app:layout_constraintStart_toEndOf="@+id/room_name"
            app:layout_constraintTop_toTopOf="@+id/button_prev_room"
            style="@style/RoomPagingButton"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:nestedScrollingEnabled="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appbar"/>
</androidx.constraintlayout.widget.ConstraintLayout>
