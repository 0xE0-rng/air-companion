<?xml version="1.0" encoding="utf-8"?>
<de.com.ideal.airpro.ui.device.schedule.subcomponents.ScheduleItemLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/margin_4dp"
    android:paddingVertical="8dp">
    <androidx.constraintlayout.widget.Group
        android:id="@+id/normal_mode"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="text_information_days,text_information_time_ranges,time_line,button_expand_item"/>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/creator_mode"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="mode_label,modes_panel,days_label,days_toggle_button_group,time_label,time_ranges_setter,schedule_btn_add_range,schedule_delete_item,button_collapse_item"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@android:color/black"
        android:gravity="center_vertical"
        android:id="@+id/mode_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_4dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:drawablePadding="7dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toStartOf="@+id/on_off_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:theme="@style/SwitchTheme"
        android:id="@+id/on_off_switch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/mode_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/mode_name"/>
    <de.com.ideal.airpro.ui.device.schedule.subcomponents.Timeline
        android:id="@+id/time_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/text_information_days"
        app:layout_constraintTop_toBottomOf="@+id/mode_name"/>
    <TextView
        android:textSize="@dimen/text_size_12sp"
        android:textColor="@android:color/black"
        android:id="@+id/text_information_days"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:foreground="?android:attr/selectableItemBackground"
        app:layout_constraintBottom_toTopOf="@+id/text_information_time_ranges"
        app:layout_constraintEnd_toStartOf="@+id/button_expand_item"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/text_size_12sp"
        android:textColor="@android:color/black"
        android:id="@+id/text_information_time_ranges"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:foreground="?android:attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/button_expand_item"
        app:layout_constraintStart_toStartOf="parent"/>
    <ImageButton
        android:id="@+id/button_expand_item"
        android:background="@drawable/round_button"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_expand_more_black_30dp"
        android:contentDescription="@string/add_schedule"
        app:layout_constraintBottom_toBottomOf="@+id/text_information_time_ranges"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/text_information_days"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:id="@+id/mode_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:text="@string/schedule_mode_label"
        app:layout_constraintTop_toBottomOf="@+id/mode_name"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/modes_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/mode_label">
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:orientation="horizontal"
            android:id="@+id/mode_toggle_button_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:selectionRequired="true"
            app:singleSelection="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/auto_btn"
                android:padding="@dimen/margin_12dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/schedule_mode_auto"
                android:drawableTop="@drawable/ic_schedule_auto_mode"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/on_off_btn"
                android:padding="@dimen/margin_12dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/schedule_mode_on"
                android:drawableTop="@drawable/ic_schedule_btn_power"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fanspeed_btn"
                android:padding="@dimen/margin_12dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/schedule_mode_fanspeed"
                android:drawableTop="@drawable/ic_schedule_btn_fan"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/led_btn"
                android:padding="@dimen/margin_12dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/schedule_mode_led"
                android:drawableTop="@drawable/ic_schedule_btn_led_brightness"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:orientation="horizontal"
            android:id="@+id/group_toggle_fan_speed_power"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/mode_toggle_button_group"
            app:selectionRequired="true"
            app:singleSelection="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fan_speed_quiet"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/mode_quiet"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fan_speed_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/mode_1"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fan_speed_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/mode_2"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fan_speed_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/mode_3"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fan_speed_turbo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/mode_turbo"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:orientation="horizontal"
            android:id="@+id/group_toggle_led_brightness"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/mode_toggle_button_group"
            app:selectionRequired="true"
            app:singleSelection="true">
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="1"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="2"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="3"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_4"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="4"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_5"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="5"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_6"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="6"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_7"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="7"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_8"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="8"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
            <com.google.android.material.button.MaterialButton
                android:textSize="@dimen/text_size_12sp"
                android:id="@+id/led_9"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="9"
                android:layout_weight="1"
                style="@style/IdealSwitchButton"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:id="@+id/days_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:text="@string/schedule_days_label"
        app:layout_constraintTop_toBottomOf="@+id/modes_panel"/>
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:orientation="horizontal"
        android:id="@+id/days_toggle_button_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/days_label"
        app:selectionRequired="false"
        app:singleSelection="false">
        <com.google.android.material.button.MaterialButton
            android:textSize="20sp"
            android:id="@+id/schedule_monday"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/abb_monday"
            android:layout_weight="1"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="20sp"
            android:id="@+id/schedule_tuesday"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/abb_tuesday"
            android:layout_weight="1"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="20sp"
            android:id="@+id/schedule_wednesday"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/abb_wednesday"
            android:layout_weight="1"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="20sp"
            android:id="@+id/schedule_thursday"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/abb_thursday"
            android:layout_weight="1"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="20sp"
            android:id="@+id/schedule_friday"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/abb_friday"
            android:layout_weight="1"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="20sp"
            android:id="@+id/schedule_saturday"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/abb_saturday"
            android:layout_weight="1"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="20sp"
            android:id="@+id/schedule_sunday"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/abb_sunday"
            android:layout_weight="1"
            style="@style/IdealSwitchButton"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>
    <TextView
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:id="@+id/time_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:text="@string/schedule_time_label"
        app:layout_constraintTop_toBottomOf="@+id/days_toggle_button_group"/>
    <androidx.recyclerview.widget.RecyclerView
        android:orientation="vertical"
        android:id="@+id/time_ranges_setter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/time_label"/>
    <com.google.android.material.button.MaterialButton
        android:textSize="@dimen/text_size_12sp"
        android:textColor="@color/colorDarkGray"
        android:id="@+id/schedule_btn_add_range"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?android:attr/selectableItemBackground"
        android:text="@string/schedule_btn_add_time_range"
        android:insetTop="0dp"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:letterSpacing="0.01"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_add_black_24dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="18dp"
        app:iconTint="@color/colorDarkGray"
        app:layout_constraintTop_toBottomOf="@+id/time_ranges_setter"
        style="@style/IdealSwitchButton"/>
    <TextView
        android:textColor="@android:color/black"
        android:gravity="center_vertical"
        android:id="@+id/schedule_delete_item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_16dp"
        android:text="@string/schedule_btn_delete"
        app:drawableStartCompat="@drawable/ic_delete_black_24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/schedule_btn_add_range"/>
    <ImageButton
        android:id="@+id/button_collapse_item"
        android:background="@drawable/round_button"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_collapse_black_24dp"
        android:contentDescription="@string/add_schedule"
        app:layout_constraintBottom_toBottomOf="@+id/schedule_delete_item"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/schedule_delete_item"/>
</de.com.ideal.airpro.ui.device.schedule.subcomponents.ScheduleItemLayout>
