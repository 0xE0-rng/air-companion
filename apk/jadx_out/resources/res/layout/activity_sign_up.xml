<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="64dp"
                android:scaleType="fitStart"
                android:contentDescription="@string/ideal_logo"
                app:srcCompat="@drawable/ideal_logo"/>
            <com.google.android.material.textfield.TextInputLayout
                android:theme="@style/TextInputLayoutAppearance"
                android:id="@+id/input_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                app:endIconMode="clear_text">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:background="@drawable/style_edit_text"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/email"
                    android:singleLine="true"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"
                    android:autofillHints="email"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:theme="@style/TextInputLayoutAppearance"
                android:id="@+id/input_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:endIconMode="password_toggle">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:background="@drawable/style_edit_text"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/password"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:imeOptions="actionNext"
                    android:autofillHints="password"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:theme="@style/TextInputLayoutAppearance"
                android:id="@+id/input_repeated_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:endIconMode="password_toggle">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:background="@drawable/style_edit_text"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/repeat_password"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:imeOptions="actionGo"
                    android:autofillHints="no"/>
            </com.google.android.material.textfield.TextInputLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <TextView
                    android:textColor="@color/colorMainText"
                    android:id="@+id/accept_pp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/i_accept"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/button_link_privacy_policy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_policy"
                    android:onClick="handleShowPrivacyPolicy"
                    android:layout_marginStart="4dp"
                    app:layout_constraintLeft_toRightOf="@+id/accept_pp"
                    app:layout_constraintRight_toLeftOf="@+id/switch_privacy_policy"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_privacy_policy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintLeft_toRightOf="@+id/button_link_privacy_policy"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:id="@+id/switch_privacy_policy_error"
                android:visibility="gone"
                style="@style/ErrorMessage"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <TextView
                    android:textColor="@color/colorMainText"
                    android:id="@+id/accept_tac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/i_accept"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/button_link_terms_and_conditions"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/terms_and_conditions"
                    android:onClick="handleShowTermsAndConditions"
                    android:layout_marginStart="4dp"
                    app:layout_constraintLeft_toRightOf="@+id/accept_tac"
                    app:layout_constraintRight_toLeftOf="@+id/switch_terms_and_conditions"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_terms_and_conditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintLeft_toRightOf="@+id/button_link_terms_and_conditions"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:id="@+id/switch_terms_and_conditions_error"
                android:visibility="gone"
                style="@style/ErrorMessage"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                <ProgressBar style="@style/ButtonSpinner"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_sign_up"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sign_up"
                    style="@style/SolidButton"/>
            </RelativeLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">
                <TextView
                    android:textColor="@android:color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/i_already_have_an_account"/>
                <TextView
                    android:textColor="@color/colorAccent"
                    android:id="@+id/button_goto_sign_in"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sign_in"
                    android:onClick="handleGotoHomeActivity"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
