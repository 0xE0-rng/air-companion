<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shop_device_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_24dp"
    android:layout_marginVertical="@dimen/margin_12dp"
    app:cardElevation="10dp"
    style="@style/CardViewStyle">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/device_preview"
            android:layout_width="90dp"
            android:layout_height="100dp"
            android:layout_margin="@dimen/margin_16dp"
            android:contentDescription="@string/air_purifier"
            app:srcCompat="@drawable/ideal_ap40_pro"/>
        <TextView
            android:textSize="@dimen/text_size_22sp"
            android:textColor="@android:color/black"
            android:id="@+id/device_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/air_purifier"/>
        <TextView
            android:textSize="@dimen/text_size_17sp"
            android:textColor="@color/colorSubText"
            android:id="@+id/device_model"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ideal_ap40_pro"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_buy_device"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_16dp"
            android:text="@string/shop_buy"
            style="@style/SolidButtonSmall"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
