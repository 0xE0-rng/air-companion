<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textAppearance="@android:style/TextAppearance"
            android:textSize="@dimen/text_size_32sp"
            android:id="@+id/text_finding_device_fragment_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8dp"
            android:text="@string/finding_device"
            android:layout_marginHorizontal="@dimen/margin_16dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginVertical="@dimen/margin_24dp">
            <androidx.constraintlayout.widget.Group
                android:id="@+id/image_radar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="image_radar_top,image_radar_bottom"/>
            <ImageView
                android:id="@+id/image_radar_bottom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:src="@drawable/radar_bottom"
                android:adjustViewBounds="true"
                android:foregroundGravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.4"
                app:layout_constraintWidth_percent="0.5"/>
            <ImageView
                android:id="@+id/image_radar_top"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:src="@drawable/radar_line"
                android:adjustViewBounds="true"
                android:foregroundGravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.4"
                app:layout_constraintWidth_percent="0.5"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_device_found"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.4"
                app:layout_constraintWidth_percent="0.5">
                <ImageView
                    android:id="@+id/image_device_ellipse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@drawable/svg_success_ellipse_black_small"
                    android:adjustViewBounds="true"
                    app:layout_constraintBottom_toBottomOf="@+id/hor_barrier_1"
                    app:layout_constraintTop_toTopOf="@+id/hor_barrier_1"
                    app:layout_constraintVertical_bias="0.4"
                    app:tint="@color/colorAccent"/>
                <ImageView
                    android:id="@+id/image_device_preview"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ideal_ap40_pro"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/device_image_preview"
                    app:layout_constraintBottom_toTopOf="@+id/hor_barrier_1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.6"/>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_16dp"
                    app:layout_constraintTop_toBottomOf="@+id/image_device_ellipse">
                    <TextView
                        android:textSize="@dimen/text_size_22sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/text_device_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/air_purifier"/>
                    <TextView
                        android:textSize="@dimen/text_size_17sp"
                        android:textColor="@color/colorAccent"
                        android:id="@+id/text_device_model"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ideal_ap40_pro"/>
                </LinearLayout>
                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/hor_barrier_1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="image_device_preview"
                    app:layout_constraintTop_toBottomOf="@+id/image_device_ellipse"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</ScrollView>
