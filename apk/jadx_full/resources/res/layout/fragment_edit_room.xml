<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/room_edit_layout"
    android:tag="layout/fragment_edit_room_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="@dimen/elevation_toolbar"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.Toolbar
            android:theme="@style/ToolbarTheme"
            android:id="@+id/activity_edit_room_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:contentInsetStart="0dp"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textStyle="bold"
                android:textColor="@android:color/holo_blue_dark"
                android:gravity="end|center_vertical"
                android:id="@+id/save_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save"
                android:layout_marginEnd="20dp"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/room_edit_layout"
        app:layout_constraintTop_toBottomOf="@+id/appbar">
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="@+id/room_edit_layout">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@android:style/TextAppearance"
                    android:textSize="@dimen/text_size_32sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_8dp"
                    android:text="@string/edit_room"
                    android:layout_marginHorizontal="@dimen/margin_16dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:theme="@style/TextInputLayoutAppearance"
                    android:id="@+id/input_room_name_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_36dp"
                    android:layout_marginHorizontal="@dimen/margin_24dp"
                    app:endIconMode="clear_text">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_room_name"
                        android:background="@drawable/style_edit_text"
                        android:padding="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/room_name"
                        android:inputType="textAutoComplete"
                        android:autofillHints="no"/>
                </com.google.android.material.textfield.TextInputLayout>
                <androidx.cardview.widget.CardView
                    android:id="@+id/button_select_room_preview_image"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_16dp"
                    android:layout_marginHorizontal="@dimen/margin_24dp"
                    app:cardElevation="0dp"
                    style="@style/ClickableCardViewStyle">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/room_photo"
                            android:background="@drawable/style_image_with_dashed_border"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:contentDescription="@string/room_image_preview"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/RoomImage"/>
                        <TextView
                            android:textSize="@dimen/text_size_17sp"
                            android:id="@+id/add_photo_placeholder"
                            android:tag="binding_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_photo"
                            android:drawablePadding="@dimen/margin_16dp"
                            app:drawableStartCompat="@drawable/ic_plus_black_24dp"
                            app:drawableTint="@color/colorDarkGray"
                            app:layout_constraintBottom_toBottomOf="@+id/room_photo"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/room_photo"/>
                        <androidx.cardview.widget.CardView
                            android:id="@+id/button_remove_image"
                            android:tag="binding_2"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/margin_8dp"
                            android:foreground="?android:attr/selectableItemBackground"
                            android:backgroundTint="@color/colorTransparentWhite"
                            app:cardCornerRadius="100dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <ImageView
                                android:tag="binding_3"
                                android:background="@android:color/transparent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/margin_16dp"
                                android:src="@drawable/ic_delete_black_24dp"
                                android:contentDescription="@string/room_image_delete"/>
                        </androidx.cardview.widget.CardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/room_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="true"/>
                <TextView
                    android:textSize="@dimen/text_size_17sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:id="@+id/delete_room"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/margin_24dp"
                    android:text="@string/delete_room"
                    android:drawablePadding="@dimen/padding_8dp"
                    app:drawableStartCompat="@drawable/ic_delete_outline_24dp"
                    app:drawableTint="@android:color/black"/>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
