<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textAppearance="@android:style/TextAppearance"
            android:textSize="@dimen/text_size_32sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8dp"
            android:text="@string/attach_device_to_room"
            android:layout_marginHorizontal="@dimen/margin_16dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_48dp"
            android:layout_marginHorizontal="@dimen/margin_24dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_room_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@+id/hor_barrier_1"
                app:layout_constraintTop_toTopOf="@+id/hor_barrier_1"
                app:layout_constraintVertical_bias="0.55">
                <ImageView
                    android:id="@+id/image_room_ellipse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@drawable/svg_success_ellipse_black"
                    android:adjustViewBounds="true"
                    app:layout_constraintBottom_toBottomOf="@+id/hor_room_barrier_1"
                    app:layout_constraintTop_toTopOf="@+id/hor_room_barrier_1"
                    app:layout_constraintVertical_bias="0.4"
                    app:tint="@color/colorAccent"/>
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_room"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:elevation="10dp"
                    app:layout_constraintBottom_toTopOf="@+id/hor_room_barrier_1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.75"
                    style="@style/CardViewStyle">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/image_room_preview"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:src="@drawable/default_room_image"
                            android:contentDescription="@string/room_image_preview"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/RoomImage"/>
                        <com.google.android.material.chip.Chip
                            android:id="@+id/text_room_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/frag_add_device_room_name"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/RoomName"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/hor_room_barrier_1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="card_room"
                    app:layout_constraintTop_toBottomOf="@+id/image_room_ellipse"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_device_view"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintWidth_percent="0.45">
                <ImageView
                    android:id="@+id/image_device_ellipse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@drawable/svg_success_ellipse_black_small"
                    android:adjustViewBounds="true"
                    app:layout_constraintBottom_toBottomOf="@+id/hor_device_barrier_1"
                    app:layout_constraintTop_toTopOf="@+id/hor_device_barrier_1"
                    app:layout_constraintVertical_bias="0.4"
                    app:tint="@color/colorAccent"/>
                <ImageView
                    android:id="@+id/image_device_preview"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ideal_ap40_pro"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/device_image_preview"
                    app:layout_constraintBottom_toTopOf="@+id/hor_device_barrier_1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.6"/>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_8dp"
                    app:layout_constraintTop_toBottomOf="@+id/image_device_ellipse">
                    <TextView
                        android:textSize="@dimen/text_size_17sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/text_device_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/air_purifier"/>
                    <TextView
                        android:textSize="@dimen/text_size_15sp"
                        android:textColor="@color/colorAccent"
                        android:id="@+id/text_device_model"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ideal_ap40_pro"/>
                </LinearLayout>
                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/hor_device_barrier_1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="image_device_preview"
                    app:layout_constraintTop_toBottomOf="@+id/image_device_ellipse"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/hor_barrier_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:barrierDirection="top"
                app:constraint_referenced_ids="layout_device_view"
                app:layout_constraintBottom_toTopOf="@+id/layout_room_view"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_next"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_24dp"
            android:text="@string/next"
            style="@style/SolidButton"/>
    </LinearLayout>
</ScrollView>
