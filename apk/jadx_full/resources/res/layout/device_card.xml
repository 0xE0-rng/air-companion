<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_layout_room"
    android:tag="layout/device_card_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_24dp"
    android:layout_marginVertical="@dimen/text_size_12sp"
    app:cardElevation="10dp"
    style="@style/CardViewStyle">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_24dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/image_purifier_device"
            android:tag="binding_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/air_sensor"
            android:layout_marginHorizontal="@dimen/margin_12dp"
            app:layout_constraintEnd_toStartOf="@+id/ver_guideline_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@+id/ver_guideline_1"
            app:layout_constraintTop_toTopOf="@+id/image_purifier_device">
            <TextView
                android:textSize="@dimen/text_size_17sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:tag="binding_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:id="@+id/device_filter_state"
                android:tag="binding_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/text_size_12sp"
                    android:textColor="@android:color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter"/>
                <TextView
                    android:textSize="@dimen/text_size_12sp"
                    android:textColor="@android:color/black"
                    android:id="@+id/device_state_value"
                    android:tag="binding_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/text_size_12sp"
                android:textColor="@android:color/black"
                android:tag="binding_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <de.com.ideal.airpro.ui.device.OnOffTextView
            android:textSize="@dimen/text_size_12sp"
            android:textColor="@color/colorRed"
            android:id="@+id/button_remove_image"
            android:tag="binding_6"
            android:padding="4dp"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_8dp"
            android:foreground="?android:attr/selectableItemBackground"
            android:text="@string/on_off"
            android:drawableTop="@drawable/ic_power_black_24dp"
            android:hapticFeedbackEnabled="true"
            android:onClick="handleOnOff"
            android:contentDescription="@string/device_power_button"
            android:textAllCaps="true"
            android:drawableTint="@color/colorRed"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <de.com.ideal.airpro.ui.device.DeviceControllerView
            android:id="@+id/device_controller"
            android:tag="binding_7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/hor_device_barrier_1"/>
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/hor_device_barrier_1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="button_remove_image"
            app:layout_constraintBottom_toTopOf="@+id/device_controller"/>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/ver_guideline_1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintGuide_percent="0.2"/>
        <de.com.ideal.airpro.ui.device.schedule.DeviceAdditionalFeatures
            android:orientation="vertical"
            android:id="@+id/device_add_features"
            android:paddingTop="@dimen/margin_24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/device_controller">
            <androidx.constraintlayout.widget.Group
                android:id="@+id/group_schedule"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:constraint_referenced_ids="schedule_list,button_add_schedule_item"/>
            <TextView
                android:enabled="false"
                android:textSize="16dp"
                android:textColor="@color/enabled_disabled_color"
                android:id="@+id/button_toggle_schedule"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:foreground="?android:attr/selectableItemBackground"
                android:text="@string/schedule"
                android:drawablePadding="7dp"
                android:layout_marginStart="32dp"
                app:drawableStartCompat="@drawable/ic_schedule"
                app:drawableTint="@color/enabled_disabled_color"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="16dp"
                android:textColor="@color/enabled_disabled_color"
                android:id="@+id/button_toggle_history"
                android:visibility="gone"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:foreground="?android:attr/selectableItemBackground"
                android:text="@string/history"
                android:drawablePadding="7dp"
                android:layout_marginEnd="32dp"
                app:drawableStartCompat="@drawable/ic_history"
                app:drawableTint="@color/enabled_disabled_color"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <de.com.ideal.airpro.ui.device.history.HistoryLayout
                android:id="@+id/history_layout"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/button_toggle_history"/>
            <androidx.recyclerview.widget.RecyclerView
                android:orientation="vertical"
                android:id="@+id/schedule_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_8dp"
                android:paddingHorizontal="@dimen/margin_24dp"
                app:layout_constraintTop_toBottomOf="@+id/button_toggle_schedule"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_add_schedule_item"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_marginTop="12dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:insetTop="0dp"
                android:textAllCaps="false"
                android:textAlignment="center"
                android:layout_marginHorizontal="24dp"
                app:cornerRadius="22dp"
                app:icon="@drawable/ic_add_black_24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:iconTint="@android:color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/schedule_list"
                style="@style/IdealSwitchButton"/>
        </de.com.ideal.airpro.ui.device.schedule.DeviceAdditionalFeatures>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
