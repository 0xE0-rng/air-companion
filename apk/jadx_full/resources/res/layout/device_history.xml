<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/history_toggle_button_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_16dp"
        android:layout_marginHorizontal="@dimen/margin_24dp"
        app:checkedButton="@+id/btn_history_hour"
        app:layout_constraintTop_toTopOf="parent"
        app:selectionRequired="true"
        app:singleSelection="true">
        <com.google.android.material.button.MaterialButton
            android:textSize="@dimen/text_size_12sp"
            android:id="@+id/btn_history_hour"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/history_hour"
            android:layout_weight="1"
            android:textAllCaps="false"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="@dimen/text_size_12sp"
            android:id="@+id/btn_history_day"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/history_day"
            android:layout_weight="1"
            android:textAllCaps="false"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="@dimen/text_size_12sp"
            android:id="@+id/btn_history_week"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/history_week"
            android:layout_weight="1"
            android:textAllCaps="false"
            style="@style/IdealSwitchButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="@dimen/text_size_12sp"
            android:id="@+id/btn_history_month"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/history_month"
            android:layout_weight="1"
            android:textAllCaps="false"
            style="@style/IdealSwitchButton"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>
    <ImageView
        android:id="@+id/btn_history_backwards"
        android:background="@drawable/ic_chevron_left_24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/btn_history_backwards"
        android:layout_marginStart="24dp"
        app:layout_constraintBottom_toBottomOf="@+id/text_history_period"
        app:layout_constraintEnd_toStartOf="@+id/text_history_period"
        app:layout_constraintHorizontal_bias="0.75"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/text_history_period"/>
    <TextView
        android:textSize="22sp"
        android:textColor="@android:color/black"
        android:id="@+id/text_history_period"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/history_toggle_button_group"/>
    <ImageView
        android:id="@+id/btn_history_forward"
        android:background="@drawable/ic_chevron_right_24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/btn_history_forward"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toBottomOf="@+id/text_history_period"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.25"
        app:layout_constraintStart_toEndOf="@+id/text_history_period"
        app:layout_constraintTop_toTopOf="@+id/text_history_period"/>
    <de.com.ideal.airpro.ui.device.history.DeviceHistory
        android:id="@+id/device_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_4dp"
        android:layout_marginHorizontal="@dimen/margin_16dp"
        app:layout_constraintTop_toBottomOf="@+id/text_history_period"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bar_label"
        android:background="@drawable/history_bar_label"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/device_history"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:textSize="8sp"
            android:textColor="@android:color/white"
            android:id="@+id/bar_label_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginHorizontal="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/bar_label_percentage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@android:color/white"
            android:id="@+id/bar_label_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginEnd="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/bar_label_details"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="10sp"
            android:textColor="@color/colorLightGray"
            android:id="@+id/bar_label_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginEnd="6dp"
            android:paddingVertical="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
